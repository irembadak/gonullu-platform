# --- SERVER CONFIG ---
PORT=3001
NODE_ENV=development

# --- DATABASE (MongoDB Atlas) ---
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname
MONGO_URI=your_mongodb_connection_string_here

# --- AUTHENTICATION (JWT) ---
# En az 32 karakterli rastgele bir cümle seçin
JWT_SECRET=your_random_secret_key_here
JWT_EXPIRE=7d

# --- FIREBASE ADMIN SDK ---
# Firebase Console > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your_project_id.firebaseio.com

# --- EMAIL CONFIG (Gmail SMTP) ---
# Google Hesap > Güvenlik > Uygulama Şifreleri kısmından alınan 16 haneli kod
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_character_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=Gönüllü Platformu <noreply@gonullu.com>

# --- AI / EXTERNAL SERVICES (Optional) ---
# Eğer Flask tarafına istek atacaksan onun URL'i
AI_SERVICE_URL=http://localhost:5000